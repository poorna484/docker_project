pipeline {
    agent any
    environment {
        DOCKER_HUB_CREDENTIALS = 'dockerhub-creds' // Jenkins credentials ID
        IMAGE_NAME = 'username/sample-app' // Replace with your Docker Hub repo
    }
    stages {
        stage('Clone Repo') {
            steps {
                git 'https://github.com/poorna484/docker_project.git'
            }
        }
        stage('Build Docker Image') {
            steps {
                script {
                    docker.build("${IMAGE_NAME}:${env.BUILD_NUMBER}")
                }
            }
        }
        stage('Login to Docker Hub') {
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', "${DOCKER_HUB_CREDENTIALS}") {
                        echo "Logged in to Docker Hub"
                    }
                }
            }
        }
        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', "${DOCKER_HUB_CREDENTIALS}") {
                        docker.image("${IMAGE_NAME}:${env.BUILD_NUMBER}").push()
                    }
                }
            }
        }
        stage('Run Docker Container') {
            steps {
                script {
                    // Remove old container if exists
                    sh 'docker rm -f sample-app || true'
                    // Run new container
                    docker.image("${IMAGE_NAME}:${env.BUILD_NUMBER}").run("-d -p 5000:5000 --name sample-app")
                }
            }
        }
    }
    post {
        always {
            echo 'Pipeline Finished'
        }
    }
}

